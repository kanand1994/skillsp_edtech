# SkillSphere secrets — DO NOT COMMIT. Copy to `.secrets` and fill in.
# Used by scripts/setup-github-secrets.sh to push to GitHub Actions secrets.

# === AWS ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ECR_REGISTRY=                       # e.g., 123456789012.dkr.ecr.us-east-1.amazonaws.com

# === EC2 deploy target ===
EC2_HOST=                           # e.g., ec2-3-90-xx-xx.compute-1.amazonaws.com
EC2_USER=ubuntu
EC2_SSH_KEY=                        # paste entire private key here (begins -----BEGIN OPENSSH PRIVATE KEY-----)

# === Frontend public API URL (consumed at build time) ===
PUBLIC_API_URL=https://api.example.com

# === Application secrets ===
EMERGENT_LLM_KEY=sk-emergent-XXXX
RESEND_API_KEY=                      # optional — leave blank for placeholder mode
STRIPE_API_KEY=sk_test_XXXX
JWT_SECRET=                          # long random string

# === Hidden SuperAdmin ===
SUPERADMIN_EMAIL=root@skillsphere.internal
SUPERADMIN_PASSWORD=
SUPERADMIN_SECRET=
SUPERADMIN_ROUTE=core-access-x7k9m2

# === Optional ===
SENDER_EMAIL=onboarding@resend.dev
GRAFANA_PASSWORD=admin

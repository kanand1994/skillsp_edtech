# ============================================================
# SkillSphere Frontend — Environment Template
# Copy this file to `frontend/.env` and fill in your own values.
# ============================================================

# Backend API base URL.
# Local dev:    http://localhost:8001
# Production:   https://api.yourdomain.com (no trailing slash, no /api suffix)
REACT_APP_BACKEND_URL=http://localhost:8001

# Webpack dev server WS port — match your reverse proxy. Set to 443 behind HTTPS.
WDS_SOCKET_PORT=443

# Disable the dev health check plugin (always false in production builds).
ENABLE_HEALTH_CHECK=false

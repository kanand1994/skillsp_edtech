# SkillSphere environment variables — copy to .env and fill in.
# DO NOT commit .env to source control.

# === Database ===
MONGO_URL=mongodb://mongodb:27017
DB_NAME=skillsphere

# === API ===
CORS_ORIGINS=*

# === Auth (JWT) ===
JWT_SECRET=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# === Hidden SuperAdmin (env-only, never stored in DB) ===
SUPERADMIN_EMAIL=root@skillsphere.internal
SUPERADMIN_PASSWORD=change-me-strong-password
SUPERADMIN_SECRET=change-me-secret-token
SUPERADMIN_ROUTE=core-access-x7k9m2

# === AI (Emergent Universal LLM Key) ===
EMERGENT_LLM_KEY=sk-emergent-XXXX

# === Stripe (use sk_test_* for development) ===
STRIPE_API_KEY=sk_test_emergent

# === Email (Resend) — leave blank to enable placeholder mode (logs only) ===
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# === Object Storage ===
APP_NAME=skillsphere

# === Frontend build arg (consumed by Dockerfile.frontend) ===
REACT_APP_BACKEND_URL=http://localhost

# === Observability ===
GRAFANA_PASSWORD=admin

# === AWS deploy (for CI/CD workflows only) ===
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# ECR_REGISTRY=
# EC2_HOST=
# EC2_USER=ubuntu
